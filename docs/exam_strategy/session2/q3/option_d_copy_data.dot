digraph option_d {
    rankdir=LR;
    bgcolor="white";
    fontname="Helvetica";
    node [fontname="Helvetica", fontsize=11, style="filled,rounded", shape=box, penwidth=1.5];
    edge [fontname="Helvetica", fontsize=9, penwidth=1.5];
    label=<<B><FONT POINT-SIZE="16">Upload Copies to Each Tool — Architecture</FONT></B>>;
    labelloc=t;
    pad=0.4;

    subgraph cluster_s3 {
        label=<<B>Amazon S3 Data Lake (Source)</B>>;
        style="filled,rounded"; fillcolor="#E8F5E9"; color="#2E7D32"; fontsize=12;
        data [label=<<B>Original Data</B><BR/>Financial datasets>, fillcolor="#3F8624", fontcolor=white];
    }

    subgraph cluster_copies {
        label=<<B>Separate Data Copies (Duplicated)</B>>;
        style="filled,rounded"; fillcolor="#FFEBEE"; color="#C62828"; fontsize=12;
        copy_hive [label=<<B>Copy for Hive</B><BR/>HDFS / S3 path>, fillcolor="#E53935", fontcolor=white];
        copy_athena [label=<<B>Copy for Athena</B><BR/>Separate S3 prefix>, fillcolor="#E53935", fontcolor=white];
        copy_redshift [label=<<B>Copy in Redshift</B><BR/>Loaded into tables>, fillcolor="#E53935", fontcolor=white];
        copy_qs [label=<<B>Copy for QuickSight</B><BR/>SPICE dataset>, fillcolor="#E53935", fontcolor=white];
    }

    subgraph cluster_issues {
        label=<<B>Problems with This Approach</B>>;
        style="filled,rounded"; fillcolor="#F5F5F5"; color="#232F3E"; fontsize=12;
        issues [shape=none, label=<
<TABLE BORDER="0" CELLBORDER="1" CELLSPACING="0" CELLPADDING="6">
  <TR>
    <TD BGCOLOR="#232F3E"><FONT COLOR="white"><B>Problem</B></FONT></TD>
    <TD BGCOLOR="#232F3E"><FONT COLOR="white"><B>Impact</B></FONT></TD>
  </TR>
  <TR>
    <TD>Data duplication</TD>
    <TD>4x storage cost</TD>
  </TR>
  <TR>
    <TD>Data inconsistency</TD>
    <TD>Copies may diverge</TD>
  </TR>
  <TR>
    <TD>Sync overhead</TD>
    <TD>Must keep all copies updated</TD>
  </TR>
  <TR>
    <TD>Operational burden</TD>
    <TD>Manage 4 separate pipelines</TD>
  </TR>
</TABLE>
        >];
    }

    data -> copy_hive [label="Copy 1", color="#C62828"];
    data -> copy_athena [label="Copy 2", color="#C62828"];
    data -> copy_redshift [label="Copy 3", color="#C62828"];
    data -> copy_qs [label="Copy 4", color="#C62828"];
}
