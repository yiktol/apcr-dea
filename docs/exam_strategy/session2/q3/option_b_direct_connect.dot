digraph option_b {
    rankdir=LR;
    bgcolor="white";
    fontname="Helvetica";
    node [fontname="Helvetica", fontsize=11, style="filled,rounded", shape=box, penwidth=1.5];
    edge [fontname="Helvetica", fontsize=9, penwidth=1.5];
    label=<<B><FONT POINT-SIZE="16">Direct S3 Connection per Tool — Architecture</FONT></B>>;
    labelloc=t;
    pad=0.4;

    subgraph cluster_s3 {
        label=<<B>Amazon S3 Data Lake</B>>;
        style="filled,rounded"; fillcolor="#E8F5E9"; color="#2E7D32"; fontsize=12;
        data [label=<<B>Data Files</B><BR/>Financial datasets>, fillcolor="#3F8624", fontcolor=white];
    }

    subgraph cluster_tools {
        label=<<B>Each Tool Configured Individually</B>>;
        style="filled,rounded"; fillcolor="#FFF9C4"; color="#F57F17"; fontsize=12;
        hive [label=<<B>Apache Hive</B><BR/>Own metastore<BR/>Own schema config>, fillcolor="#F57F17", fontcolor=white];
        athena [label=<<B>Amazon Athena</B><BR/>Own table defs<BR/>Own DDL scripts>, fillcolor="#F57F17", fontcolor=white];
        redshift [label=<<B>Amazon Redshift</B><BR/>Own external schema<BR/>Own IAM config>, fillcolor="#F57F17", fontcolor=white];
        quicksight [label=<<B>Amazon QuickSight</B><BR/>Own data source<BR/>Own connection>, fillcolor="#F57F17", fontcolor=white];
    }

    subgraph cluster_overhead {
        label=<<B>Operational Overhead</B>>;
        style="filled,rounded"; fillcolor="#F5F5F5"; color="#232F3E"; fontsize=12;
        overhead [shape=none, label=<
<TABLE BORDER="0" CELLBORDER="1" CELLSPACING="0" CELLPADDING="6">
  <TR>
    <TD BGCOLOR="#232F3E"><FONT COLOR="white"><B>Issue</B></FONT></TD>
    <TD BGCOLOR="#232F3E"><FONT COLOR="white"><B>Impact</B></FONT></TD>
  </TR>
  <TR>
    <TD>Schema defined per tool</TD>
    <TD>Duplicate effort, drift risk</TD>
  </TR>
  <TR>
    <TD>No shared catalog</TD>
    <TD>Inconsistent metadata</TD>
  </TR>
  <TR>
    <TD>Individual IAM setup</TD>
    <TD>Complex access management</TD>
  </TR>
  <TR>
    <TD>Schema changes</TD>
    <TD>Must update every tool</TD>
  </TR>
</TABLE>
        >];
    }

    data -> hive [label="Direct\naccess", color="#F57F17"];
    data -> athena [color="#F57F17"];
    data -> redshift [color="#F57F17"];
    data -> quicksight [color="#F57F17"];
}
