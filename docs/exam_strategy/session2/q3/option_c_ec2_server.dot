digraph option_c {
    rankdir=LR;
    bgcolor="white";
    fontname="Helvetica";
    node [fontname="Helvetica", fontsize=11, style="filled,rounded", shape=box, penwidth=1.5];
    edge [fontname="Helvetica", fontsize=9, penwidth=1.5];
    label=<<B><FONT POINT-SIZE="16">EC2 Central Analysis Server — Architecture</FONT></B>>;
    labelloc=t;
    pad=0.4;

    subgraph cluster_s3 {
        label=<<B>Amazon S3 Data Lake</B>>;
        style="filled,rounded"; fillcolor="#E8F5E9"; color="#2E7D32"; fontsize=12;
        data [label=<<B>Data Files</B><BR/>Financial datasets>, fillcolor="#3F8624", fontcolor=white];
    }

    subgraph cluster_ec2 {
        label=<<B>Amazon EC2 (Self-Managed)</B>>;
        style="filled,rounded"; fillcolor="#FFEBEE"; color="#C62828"; fontsize=12;
        ec2 [label=<<B>EC2 Instance</B><BR/>Central analysis server<BR/>Must manage: OS, scaling,<BR/>patching, storage, backups>, fillcolor="#C62828", fontcolor=white];
        local_disk [label=<<B>Local / EBS Storage</B><BR/>Data copied from S3<BR/>Capacity management>, fillcolor="#E53935", fontcolor=white];
    }

    subgraph cluster_tools {
        label=<<B>Analysis Tools</B>>;
        style="filled,rounded"; fillcolor="#E3F2FD"; color="#1565C0"; fontsize=12;
        hive [label=<<B>Apache Hive</B>>, fillcolor="#1565C0", fontcolor=white];
        athena [label=<<B>Amazon Athena</B>>, fillcolor="#1565C0", fontcolor=white];
        redshift [label=<<B>Amazon Redshift</B>>, fillcolor="#1565C0", fontcolor=white];
        quicksight [label=<<B>Amazon QuickSight</B>>, fillcolor="#6A1B9A", fontcolor=white];
    }

    data -> ec2 [label="Export data\nfrom S3", color="#C62828"];
    ec2 -> local_disk [label="Store\nlocally", color="#E53935"];
    ec2 -> hive [label="Serve data", color="#1565C0", style=dashed];
    ec2 -> athena [color="#1565C0", style=dashed];
    ec2 -> redshift [color="#1565C0", style=dashed];
    ec2 -> quicksight [color="#6A1B9A", style=dashed];
}
