digraph option_d {
    rankdir=LR;
    bgcolor="white";
    fontname="Helvetica";
    node [fontname="Helvetica", fontsize=11, style="filled,rounded", shape=box, penwidth=1.5];
    edge [fontname="Helvetica", fontsize=9, penwidth=1.5];
    label=<<B><FONT POINT-SIZE="16">S3 Standard-IA + S3 Glacier Instant Retrieval</FONT></B>>;
    labelloc=t;
    pad=0.4;

    subgraph cluster_content {
        label=<<B>Video Streaming Content</B>>;
        style="filled,rounded"; fillcolor="#E3F2FD"; color="#1565C0"; fontsize=12;
        hot [label=<<B>Frequently Accessed</B><BR/>Popular / trending<BR/>videos>, fillcolor="#1565C0", fontcolor=white];
        cold [label=<<B>Older Content</B><BR/>Accessed once<BR/>per quarter>, fillcolor="#455A64", fontcolor=white];
    }

    subgraph cluster_s3 {
        label=<<B>Amazon S3 Storage Classes</B>>;
        style="filled,rounded"; fillcolor="#FFEBEE"; color="#C62828"; fontsize=12;
        ia [label=<<B>S3 Standard-IA</B><BR/>$0.01/GB retrieval fee<BR/>30-day minimum charge<BR/>NOT for frequent access>, fillcolor="#C62828", fontcolor=white];
        glacier_ir [label=<<B>S3 Glacier Instant Retrieval</B><BR/>Millisecond access<BR/>Good for quarterly<BR/>(correct for cold data)>, fillcolor="#00695C", fontcolor=white];
    }

    subgraph cluster_issue {
        label=<<B>S3 Standard-IA for Frequent Access</B>>;
        style="filled,rounded"; fillcolor="#F5F5F5"; color="#232F3E"; fontsize=12;
        issue [shape=none, label=<
<TABLE BORDER="0" CELLBORDER="1" CELLSPACING="0" CELLPADDING="6">
  <TR>
    <TD BGCOLOR="#232F3E"><FONT COLOR="white"><B>Problem</B></FONT></TD>
    <TD BGCOLOR="#232F3E"><FONT COLOR="white"><B>Impact</B></FONT></TD>
  </TR>
  <TR>
    <TD>$0.01/GB retrieval fee</TD>
    <TD BGCOLOR="#FFCDD2">Adds up fast with frequent access</TD>
  </TR>
  <TR>
    <TD>30-day minimum storage</TD>
    <TD BGCOLOR="#FFCDD2">Charged even if deleted early</TD>
  </TR>
  <TR>
    <TD>128 KB minimum object size</TD>
    <TD BGCOLOR="#FFCDD2">Small files charged as 128 KB</TD>
  </TR>
</TABLE>
        >];
    }

    hot -> ia [label="Wrong class\nfor frequent", color="#C62828", style=dashed];
    cold -> glacier_ir [label="Correct for\nquarterly", color="#00695C"];
}
