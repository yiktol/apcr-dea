digraph option_a {
    rankdir=LR;
    bgcolor="white";
    fontname="Helvetica";
    node [fontname="Helvetica", fontsize=11, style="filled,rounded", shape=box, penwidth=1.5];
    edge [fontname="Helvetica", fontsize=9, penwidth=1.5];
    label=<<B><FONT POINT-SIZE="16">S3 Standard + S3 Glacier Instant Retrieval</FONT></B>>;
    labelloc=t;
    pad=0.4;

    subgraph cluster_content {
        label=<<B>Video Streaming Content</B>>;
        style="filled,rounded"; fillcolor="#E3F2FD"; color="#1565C0"; fontsize=12;
        hot [label=<<B>Frequently Accessed</B><BR/>Popular / trending<BR/>videos>, fillcolor="#1565C0", fontcolor=white];
        cold [label=<<B>Older Content</B><BR/>Accessed once<BR/>per quarter>, fillcolor="#455A64", fontcolor=white];
    }

    subgraph cluster_s3 {
        label=<<B>Amazon S3 Storage Classes</B>>;
        style="filled,rounded"; fillcolor="#E8F5E9"; color="#2E7D32"; fontsize=12;
        standard [label=<<B>S3 Standard</B><BR/>Millisecond access<BR/>High throughput<BR/>No retrieval fee>, fillcolor="#3F8624", fontcolor=white];
        glacier_ir [label=<<B>S3 Glacier Instant Retrieval</B><BR/>Millisecond access<BR/>68% cheaper than S3 Standard-IA<BR/>for once-per-quarter access<BR/>Higher retrieval cost>, fillcolor="#00695C", fontcolor=white];
    }

    subgraph cluster_cost {
        label=<<B>Cost Comparison (per GB/month)</B>>;
        style="filled,rounded"; fillcolor="#F5F5F5"; color="#232F3E"; fontsize=12;
        cost [shape=none, label=<
<TABLE BORDER="0" CELLBORDER="1" CELLSPACING="0" CELLPADDING="6">
  <TR>
    <TD BGCOLOR="#232F3E"><FONT COLOR="white"><B>Class</B></FONT></TD>
    <TD BGCOLOR="#232F3E"><FONT COLOR="white"><B>Storage</B></FONT></TD>
    <TD BGCOLOR="#232F3E"><FONT COLOR="white"><B>Retrieval</B></FONT></TD>
    <TD BGCOLOR="#232F3E"><FONT COLOR="white"><B>Best For</B></FONT></TD>
  </TR>
  <TR>
    <TD>S3 Standard</TD>
    <TD>$0.023</TD>
    <TD>Free</TD>
    <TD>Frequent access</TD>
  </TR>
  <TR>
    <TD>S3 Standard-IA</TD>
    <TD>$0.0125</TD>
    <TD>$0.01/GB</TD>
    <TD>Monthly access</TD>
  </TR>
  <TR>
    <TD BGCOLOR="#C8E6C9"><B>Glacier Instant</B></TD>
    <TD BGCOLOR="#C8E6C9"><B>$0.004</B></TD>
    <TD BGCOLOR="#C8E6C9">$0.03/GB</TD>
    <TD BGCOLOR="#C8E6C9"><B>Quarterly access</B></TD>
  </TR>
</TABLE>
        >];
    }

    hot -> standard [label="High\nthroughput", color="#3F8624"];
    cold -> glacier_ir [label="Once per\nquarter", color="#00695C"];
}
