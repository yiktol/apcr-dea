digraph option_c {
    rankdir=LR;
    bgcolor="white";
    fontname="Helvetica";
    node [fontname="Helvetica", fontsize=11, style="filled,rounded", shape=box, penwidth=1.5];
    edge [fontname="Helvetica", fontsize=9, penwidth=1.5];
    label=<<B><FONT POINT-SIZE="16">S3 Glacier Instant Retrieval + S3 Glacier Deep Archive</FONT></B>>;
    labelloc=t;
    pad=0.4;

    subgraph cluster_content {
        label=<<B>Video Streaming Content</B>>;
        style="filled,rounded"; fillcolor="#E3F2FD"; color="#1565C0"; fontsize=12;
        hot [label=<<B>Frequently Accessed</B><BR/>Popular / trending<BR/>videos>, fillcolor="#1565C0", fontcolor=white];
        cold [label=<<B>Older Content</B><BR/>Accessed once<BR/>per quarter>, fillcolor="#455A64", fontcolor=white];
    }

    subgraph cluster_s3 {
        label=<<B>Amazon S3 Storage Classes</B>>;
        style="filled,rounded"; fillcolor="#FFEBEE"; color="#C62828"; fontsize=12;
        glacier_ir [label=<<B>S3 Glacier Instant Retrieval</B><BR/>Millisecond access BUT<BR/>high retrieval cost<BR/>NOT for frequent access>, fillcolor="#C62828", fontcolor=white];
        deep [label=<<B>S3 Glacier Deep Archive</B><BR/>12-48 hour retrieval<BR/>Lowest storage cost<BR/>NOT for quarterly access>, fillcolor="#B71C1C", fontcolor=white];
    }

    subgraph cluster_issue {
        label=<<B>Why This Fails</B>>;
        style="filled,rounded"; fillcolor="#F5F5F5"; color="#232F3E"; fontsize=12;
        issue [shape=none, label=<
<TABLE BORDER="0" CELLBORDER="1" CELLSPACING="0" CELLPADDING="6">
  <TR>
    <TD BGCOLOR="#232F3E"><FONT COLOR="white"><B>Class</B></FONT></TD>
    <TD BGCOLOR="#232F3E"><FONT COLOR="white"><B>Problem</B></FONT></TD>
  </TR>
  <TR>
    <TD>Glacier Instant for hot data</TD>
    <TD BGCOLOR="#FFCDD2">Expensive retrieval on every access</TD>
  </TR>
  <TR>
    <TD>Deep Archive for quarterly</TD>
    <TD BGCOLOR="#FFCDD2">12-48 hr retrieval — not instant</TD>
  </TR>
</TABLE>
        >];
    }

    hot -> glacier_ir [label="Wrong class\nfor frequent", color="#C62828", style=dashed];
    cold -> deep [label="Too slow\nfor quarterly", color="#C62828", style=dashed];
}
