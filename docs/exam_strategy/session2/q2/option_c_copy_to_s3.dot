digraph option_c {
    rankdir=LR;
    bgcolor="white";
    fontname="Helvetica";
    node [fontname="Helvetica", fontsize=11, style="filled,rounded", shape=box, penwidth=1.5];
    edge [fontname="Helvetica", fontsize=9, penwidth=1.5];
    label=<<B><FONT POINT-SIZE="16">COPY Command — Actual Data Direction</FONT></B>>;
    labelloc=t;
    pad=0.4;

    subgraph cluster_s3 {
        label=<<B>Amazon S3</B>>;
        style="filled,rounded"; fillcolor="#E8F5E9"; color="#2E7D32"; fontsize=12;
        s3_files [label=<<B>Data Files in S3</B><BR/>CSV / Parquet / JSON<BR/>Avro / ORC>, fillcolor="#3F8624", fontcolor=white];
    }

    subgraph cluster_redshift {
        label=<<B>Amazon Redshift Cluster</B>>;
        style="filled,rounded"; fillcolor="#E3F2FD"; color="#1565C0"; fontsize=12;
        copy_cmd [label=<<B>COPY Command</B><BR/>Loads data INTO<BR/>Redshift tables<BR/>(MPP parallel load)>, fillcolor="#FF9900", fontcolor=white];
        table [label=<<B>Redshift Table</B><BR/>Target table<BR/>for loaded data>, fillcolor="#1565C0", fontcolor=white];
    }

    subgraph cluster_commands {
        label=<<B>Command Direction Reference</B>>;
        style="filled,rounded"; fillcolor="#F5F5F5"; color="#232F3E"; fontsize=12;

        cmds [shape=none, label=<
<TABLE BORDER="0" CELLBORDER="1" CELLSPACING="0" CELLPADDING="6">
  <TR>
    <TD BGCOLOR="#232F3E"><FONT COLOR="white"><B>Command</B></FONT></TD>
    <TD BGCOLOR="#232F3E"><FONT COLOR="white"><B>Direction</B></FONT></TD>
    <TD BGCOLOR="#232F3E"><FONT COLOR="white"><B>Purpose</B></FONT></TD>
  </TR>
  <TR>
    <TD><B>COPY</B></TD>
    <TD>S3 → Redshift</TD>
    <TD>Load data INTO cluster</TD>
  </TR>
  <TR>
    <TD><B>UNLOAD</B></TD>
    <TD>Redshift → S3</TD>
    <TD>Export data OUT of cluster</TD>
  </TR>
</TABLE>
        >];
    }

    s3_files -> copy_cmd [label="COPY loads\ndata INTO\nRedshift", color="#FF9900", penwidth=2.5];
    copy_cmd -> table [label="Parallel\ninsert", color="#1565C0"];
}
