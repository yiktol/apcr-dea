digraph option_d {
    rankdir=LR;
    bgcolor="white";
    fontname="Helvetica";
    node [fontname="Helvetica", fontsize=11, style="filled,rounded", shape=box, penwidth=1.5];
    edge [fontname="Helvetica", fontsize=9, penwidth=1.5];
    label=<<B><FONT POINT-SIZE="16">UNLOAD to S3 as Parquet — Architecture</FONT></B>>;
    labelloc=t;
    pad=0.4;

    subgraph cluster_redshift {
        label=<<B>Amazon Redshift Cluster</B>>;
        style="filled,rounded"; fillcolor="#E3F2FD"; color="#1565C0"; fontsize=12;
        table [label=<<B>Source Table</B><BR/>Data older than<BR/>6 months>, fillcolor="#1565C0", fontcolor=white];
        unload [label=<<B>UNLOAD Command</B><BR/>Exports query results<BR/>FORMAT AS PARQUET<BR/>PARTITION BY columns>, fillcolor="#FF9900", fontcolor=white];
    }

    subgraph cluster_s3 {
        label=<<B>Amazon S3</B>>;
        style="filled,rounded"; fillcolor="#E8F5E9"; color="#2E7D32"; fontsize=12;
        parquet [label=<<B>Parquet Files</B><BR/>Columnar format<BR/>Compressed &amp; efficient<BR/>Schema embedded>, fillcolor="#3F8624", fontcolor=white];
    }

    subgraph cluster_benefits {
        label=<<B>Why Parquet for Analytics</B>>;
        style="filled,rounded"; fillcolor="#F5F5F5"; color="#232F3E"; fontsize=12;

        benefits [shape=none, label=<
<TABLE BORDER="0" CELLBORDER="1" CELLSPACING="0" CELLPADDING="6">
  <TR>
    <TD BGCOLOR="#232F3E"><FONT COLOR="white"><B>Feature</B></FONT></TD>
    <TD BGCOLOR="#232F3E"><FONT COLOR="white"><B>Benefit</B></FONT></TD>
  </TR>
  <TR>
    <TD>Columnar Storage</TD>
    <TD BGCOLOR="#C8E6C9">Read only needed columns</TD>
  </TR>
  <TR>
    <TD>Built-in Compression</TD>
    <TD BGCOLOR="#C8E6C9">Lower S3 storage cost</TD>
  </TR>
  <TR>
    <TD>Schema Embedded</TD>
    <TD BGCOLOR="#C8E6C9">Self-describing files</TD>
  </TR>
  <TR>
    <TD>Predicate Pushdown</TD>
    <TD BGCOLOR="#C8E6C9">Skip irrelevant row groups</TD>
  </TR>
  <TR>
    <TD>Partition Support</TD>
    <TD BGCOLOR="#C8E6C9">UNLOAD PARTITION BY columns</TD>
  </TR>
</TABLE>
        >];
    }

    table -> unload [label="SELECT where\nage > 6 months", color="#1565C0"];
    unload -> parquet [label="Export as\nParquet files", color="#3F8624"];
}
