digraph option_d {
    rankdir=LR;
    bgcolor="white";
    fontname="Helvetica";
    node [fontname="Helvetica", fontsize=11, style="filled,rounded", shape=box, penwidth=1.5];
    edge [fontname="Helvetica", fontsize=9, penwidth=1.5];
    label=<<B><FONT POINT-SIZE="16">AWS Snowball — Migration Workflow</FONT></B>>;
    labelloc=t;
    pad=0.4;

    subgraph cluster_flow {
        label=<<B>Snowball Edge Migration — 5 PB Historical Data</B>>;
        style="filled,rounded"; fillcolor="#F5F5F5"; color="#232F3E"; fontsize=12; penwidth=1.5;

        step1 [label=<<B>1. ORDER</B><BR/>Request Snowball Edge<BR/>via Snow Family Console<BR/>~210 TB usable each>, fillcolor="#FF9900", fontcolor=white];
        step2 [label=<<B>2. RECEIVE</B><BR/>AWS ships devices<BR/>to data center<BR/>(tamper-evident case)>, fillcolor="#FF9900", fontcolor=white];
        step3 [label=<<B>3. LOAD DATA</B><BR/>Connect to local network<BR/>Copy 5 PB via NFS or<BR/>S3-compatible API>, fillcolor="#1565C0", fontcolor=white];
        step4 [label=<<B>4. RETURN</B><BR/>Ship devices back<BR/>to AWS via carrier<BR/>(E-ink label update)>, fillcolor="#FF9900", fontcolor=white];
        step5 [label=<<B>5. IMPORT</B><BR/>AWS imports data<BR/>into Amazon S3<BR/>Device sanitized>, fillcolor="#3F8624", fontcolor=white];

        step1 -> step2 [label="AWS ships\nto you", color="#FF9900"];
        step2 -> step3 [label="Connect &\npower on", color="#1565C0"];
        step3 -> step4 [label="Data loaded\nship back", color="#FF9900"];
        step4 -> step5 [label="AWS receives\n& imports", color="#3F8624"];
    }

    subgraph cluster_specs {
        label=<<B>Device Specifications</B>>;
        style="filled,rounded"; fillcolor="#F5F5F5"; color="#232F3E"; fontsize=12;

        specs [shape=none, label=<
<TABLE BORDER="0" CELLBORDER="1" CELLSPACING="0" CELLPADDING="6">
  <TR>
    <TD BGCOLOR="#232F3E"><FONT COLOR="white"><B>Spec</B></FONT></TD>
    <TD BGCOLOR="#232F3E"><FONT COLOR="white"><B>Value</B></FONT></TD>
  </TR>
  <TR>
    <TD>Usable Capacity</TD>
    <TD>~210 TB (Storage Optimized)</TD>
  </TR>
  <TR>
    <TD>Devices for 5 PB</TD>
    <TD>~24 devices (5000 / 210)</TD>
  </TR>
  <TR>
    <TD>Encryption</TD>
    <TD>256-bit (KMS managed)</TD>
  </TR>
  <TR>
    <TD>Physical Security</TD>
    <TD>Tamper-resistant, TPM</TD>
  </TR>
  <TR>
    <TD>Network Interface</TD>
    <TD>10 / 25 / 40 / 100 GbE</TD>
  </TR>
</TABLE>
        >];
    }
}
