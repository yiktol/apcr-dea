digraph option_c {
    rankdir=LR;
    bgcolor="white";
    fontname="Helvetica";
    node [fontname="Helvetica", fontsize=11, style="filled,rounded", shape=box, penwidth=1.5];
    edge [fontname="Helvetica", fontsize=9, penwidth=1.5];
    label=<<B><FONT POINT-SIZE="16">S3 Transfer Acceleration — Architecture</FONT></B>>;
    labelloc=t;
    pad=0.4;

    subgraph cluster_onprem {
        label=<<B>On-Premises</B>>;
        style="filled,rounded"; fillcolor="#E3F2FD"; color="#1565C0"; fontsize=12;
        data [label=<<B>Monthly Data</B><BR/>3 TB/month<BR/>new records>, fillcolor="#6A1B9A", fontcolor=white];
        client [label=<<B>Upload Client</B><BR/>S3 API using<BR/>accelerate endpoint<BR/>(bucketname.s3-accelerate)>, fillcolor="#1565C0", fontcolor=white];
    }

    subgraph cluster_edge {
        label=<<B>CloudFront Edge Network (50+ PoPs)</B>>;
        style="filled,rounded"; fillcolor="#FFF3E0"; color="#FF9900"; fontsize=12;
        edge_loc [label=<<B>Nearest Edge Location</B><BR/>Receives upload<BR/>via public internet>, fillcolor="#FF9900", fontcolor=white];
    }

    subgraph cluster_backbone {
        label=<<B>AWS Internal Network</B>>;
        style="filled,rounded"; fillcolor="#F3E5F5"; color="#6A1B9A"; fontsize=12;
        backbone [label=<<B>Optimized Backbone</B><BR/>AWS managed routing<BR/>to destination region>, fillcolor="#6A1B9A", fontcolor=white];
    }

    subgraph cluster_aws {
        label=<<B>AWS Cloud</B>>;
        style="filled,rounded"; fillcolor="#E8F5E9"; color="#2E7D32"; fontsize=12;
        s3 [label=<<B>Amazon S3</B><BR/>Destination bucket<BR/>(acceleration enabled)>, fillcolor="#3F8624", fontcolor=white];
        redshift [label=<<B>Amazon Redshift</B><BR/>Query engine>, fillcolor="#1565C0", fontcolor=white];
    }

    data -> client [color="#6A1B9A"];
    client -> edge_loc [label="Internet to\nnearest PoP", color="#FF9900"];
    edge_loc -> backbone [label="Optimized\nrouting", color="#6A1B9A"];
    backbone -> s3 [label="Deliver to\nS3 region", color="#3F8624"];
    s3 -> redshift [label="Query", color="#1565C0", style=dashed];
}
