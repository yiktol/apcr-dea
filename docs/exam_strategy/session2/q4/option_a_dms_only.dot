digraph option_a {
    rankdir=LR;
    bgcolor="white";
    fontname="Helvetica";
    node [fontname="Helvetica", fontsize=11, style="filled,rounded", shape=box, penwidth=1.5];
    edge [fontname="Helvetica", fontsize=9, penwidth=1.5];
    label=<<B><FONT POINT-SIZE="16">AWS DMS Only — Architecture</FONT></B>>;
    labelloc=t;
    pad=0.4;

    subgraph cluster_source {
        label=<<B>On-Premises Database</B>>;
        style="filled,rounded"; fillcolor="#E3F2FD"; color="#1565C0"; fontsize=12;
        src_db [label=<<B>Source Database</B><BR/>Oracle / SQL Server<BR/>Schema + Data>, fillcolor="#1565C0", fontcolor=white];
        src_app [label=<<B>Application Code</B><BR/>Embedded SQL<BR/>statements>, fillcolor="#455A64", fontcolor=white];
    }

    subgraph cluster_dms {
        label=<<B>AWS DMS</B>>;
        style="filled,rounded"; fillcolor="#FFF3E0"; color="#FF9900"; fontsize=12;
        repl [label=<<B>Replication Instance</B><BR/>Full load + CDC<BR/>Data migration only>, fillcolor="#FF9900", fontcolor=white];
    }

    subgraph cluster_target {
        label=<<B>Amazon RDS</B>>;
        style="filled,rounded"; fillcolor="#E8F5E9"; color="#2E7D32"; fontsize=12;
        tgt_db [label=<<B>Target Database</B><BR/>MySQL / PostgreSQL<BR/>Aurora>, fillcolor="#3F8624", fontcolor=white];
    }

    subgraph cluster_gap {
        label=<<B>What DMS Does NOT Do</B>>;
        style="filled,rounded"; fillcolor="#F5F5F5"; color="#232F3E"; fontsize=12;
        gap [shape=none, label=<
<TABLE BORDER="0" CELLBORDER="1" CELLSPACING="0" CELLPADDING="6">
  <TR>
    <TD BGCOLOR="#232F3E"><FONT COLOR="white"><B>Capability</B></FONT></TD>
    <TD BGCOLOR="#232F3E"><FONT COLOR="white"><B>DMS</B></FONT></TD>
  </TR>
  <TR>
    <TD>Schema conversion</TD>
    <TD BGCOLOR="#FFCDD2">NO</TD>
  </TR>
  <TR>
    <TD>Stored procedure conversion</TD>
    <TD BGCOLOR="#FFCDD2">NO</TD>
  </TR>
  <TR>
    <TD>Application SQL scanning</TD>
    <TD BGCOLOR="#FFCDD2">NO</TD>
  </TR>
  <TR>
    <TD>Data migration</TD>
    <TD BGCOLOR="#C8E6C9">YES</TD>
  </TR>
</TABLE>
        >];
    }

    src_db -> repl [label="Data only", color="#FF9900"];
    repl -> tgt_db [label="Migrate\ndata", color="#3F8624"];
    src_app -> repl [label="SQL scan?", color="#C62828", style=dashed];
}
