digraph option_d {
    rankdir=LR;
    bgcolor="white";
    fontname="Helvetica";
    node [fontname="Helvetica", fontsize=11, style="filled,rounded", shape=box, penwidth=1.5];
    edge [fontname="Helvetica", fontsize=9, penwidth=1.5];
    label=<<B><FONT POINT-SIZE="16">AWS SCT + Transfer Family — Architecture</FONT></B>>;
    labelloc=t;
    pad=0.4;

    subgraph cluster_source {
        label=<<B>On-Premises</B>>;
        style="filled,rounded"; fillcolor="#E3F2FD"; color="#1565C0"; fontsize=12;
        src_db [label=<<B>Source Database</B><BR/>Oracle / SQL Server<BR/>Schema + Data>, fillcolor="#1565C0", fontcolor=white];
    }

    subgraph cluster_sct {
        label=<<B>AWS SCT</B>>;
        style="filled,rounded"; fillcolor="#F3E5F5"; color="#6A1B9A"; fontsize=12;
        schema_conv [label=<<B>Schema Conversion</B><BR/>Converts DDL,<BR/>procedures, functions>, fillcolor="#6A1B9A", fontcolor=white];
    }

    subgraph cluster_transfer {
        label=<<B>AWS Transfer Family</B>>;
        style="filled,rounded"; fillcolor="#FFEBEE"; color="#C62828"; fontsize=12;
        transfer [label=<<B>Transfer Family</B><BR/>SFTP / FTPS / FTP<BR/>File transfer to S3<BR/>NOT for DB migration>, fillcolor="#C62828", fontcolor=white];
    }

    subgraph cluster_target {
        label=<<B>Amazon RDS</B>>;
        style="filled,rounded"; fillcolor="#E8F5E9"; color="#2E7D32"; fontsize=12;
        tgt_db [label=<<B>Target Database</B><BR/>Schema applied but<BR/>data not migrated<BR/>properly>, fillcolor="#3F8624", fontcolor=white];
    }

    subgraph cluster_compare {
        label=<<B>Transfer Family vs DMS</B>>;
        style="filled,rounded"; fillcolor="#F5F5F5"; color="#232F3E"; fontsize=12;
        cmp [shape=none, label=<
<TABLE BORDER="0" CELLBORDER="1" CELLSPACING="0" CELLPADDING="6">
  <TR>
    <TD BGCOLOR="#232F3E"><FONT COLOR="white"><B>Feature</B></FONT></TD>
    <TD BGCOLOR="#232F3E"><FONT COLOR="white"><B>Transfer Family</B></FONT></TD>
    <TD BGCOLOR="#232F3E"><FONT COLOR="white"><B>AWS DMS</B></FONT></TD>
  </TR>
  <TR>
    <TD>Purpose</TD>
    <TD BGCOLOR="#FFEBEE">FTP file transfers</TD>
    <TD BGCOLOR="#C8E6C9">Database migration</TD>
  </TR>
  <TR>
    <TD>Target</TD>
    <TD BGCOLOR="#FFEBEE">S3 / EFS</TD>
    <TD BGCOLOR="#C8E6C9">RDS / Aurora / etc.</TD>
  </TR>
  <TR>
    <TD>CDC support</TD>
    <TD BGCOLOR="#FFEBEE">No</TD>
    <TD BGCOLOR="#C8E6C9">Yes</TD>
  </TR>
</TABLE>
        >];
    }

    src_db -> schema_conv [label="Convert\nschema", color="#6A1B9A"];
    schema_conv -> tgt_db [label="Apply\nschema", color="#6A1B9A"];
    src_db -> transfer [label="Data?", color="#C62828", style=dashed];
    transfer -> tgt_db [label="Wrong tool\nfor DB data", color="#C62828", style=dashed];
}
